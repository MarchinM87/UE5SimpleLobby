{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DedicatedServer": {
    "Enabled": false,
    "ExecutablePath": "",
    "WorkingDirectory": "",
    "HostIp": "127.0.0.1",
    "PortRangeStart": 7777,
    "PortRangeEnd": 7877,
    "ArgumentsTemplate": "{map} -port={port} -log",
    "StartupDelayMs": 1500,
    "KillProcessTreeOnStop": true
  }
}
